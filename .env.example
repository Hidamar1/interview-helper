# Neon PostgreSQL（pooled 连接串，运行时用）
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Neon 直连串（migrate 用，Neon 控制台「unpooled」）
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# 本地替代方案（Docker）：
# docker run -d --name ih-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=interview -p 5432:5432 postgres:17
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interview"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/interview"
